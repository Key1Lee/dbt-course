# Copy this file to .env. Never commit .env or a private key.
# These names intentionally match the dbt profile where possible.
SNOWFLAKE_ACCOUNT=your_organization-your_account
DBT_USER=your_snowflake_username
SNOWFLAKE_ROLE=REPORTER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AIRBNB
SNOWFLAKE_SCHEMA=DBT_YOUR_NAME
DBT_ENV_NAME=YOUR_NAME

# Option A (recommended for this course): encrypted PKCS#8 key-pair authentication.
SNOWFLAKE_AUTHENTICATOR=SNOWFLAKE_JWT
SNOWFLAKE_PRIVATE_KEY_PATH=C:\Users\your_name\.snowflake\rsa_key.p8
PRIVATE_KEY_PASSPHRASE=replace_with_your_key_passphrase

# To reuse dbt's inline PRIVATE_KEY variable, comment out the path above and use:
# PRIVATE_KEY="-----BEGIN ENCRYPTED PRIVATE KEY-----\n...\n-----END ENCRYPTED PRIVATE KEY-----"

# Option B: password/MFA (comment out Option A first).
# SNOWFLAKE_AUTHENTICATOR=USERNAME_PASSWORD_MFA
# SNOWFLAKE_PASSWORD=replace_with_your_password

# Option C: browser SSO (comment out Option A first; account and user are still required).
# SNOWFLAKE_AUTHENTICATOR=EXTERNALBROWSER
